# ─────────────────────────────────────────────────────────────────────────────
# Xcode build output
# ─────────────────────────────────────────────────────────────────────────────
build/
DerivedData/
*.xcuserstate
*.xcuserdatad/
xcuserdata/
*.xcworkspace/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/

# Generated Xcode project (regenerated from project.yml by xcodegen)
Work.xcodeproj/

# Swift Package Manager
.swiftpm/
.build/
Packages/
Package.resolved

# ─────────────────────────────────────────────────────────────────────────────
# macOS / Finder noise
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon?

# ─────────────────────────────────────────────────────────────────────────────
# Release artifacts (regenerated by release.sh / build pipeline)
# ─────────────────────────────────────────────────────────────────────────────
Work.dmg
Work-*.dmg
docs/Work-*.dmg
Atelier.dmg
Atelier-*.dmg
docs/Atelier-*.dmg
# docs/Work.dmg (legacy alias) and docs/Atelier.dmg (latest alias) are
# tracked deliberately — they're the site's download targets.
*.dSYM/
*.dSYM.zip

# ─────────────────────────────────────────────────────────────────────────────
# Sensitive / never-commit
# ─────────────────────────────────────────────────────────────────────────────
# Code-signing certs + private keys — these live in ~/Documents/work-signing/
# locally and in macOS Keychain. They must NEVER enter the repo.
*.cer
*.p12
*.pem
*.key
WorkCSR*
developerID_*

# Distribution entitlements (generated to /tmp by release.sh)
Work-dist.entitlements

# Environment files
.env
.env.local
.env.*.local

# Apple notarytool keychain profiles are stored in Keychain, but if any
# auth artifacts get dumped to disk during debug, ignore them:
*-credentials.json
notary-*.json

# ─────────────────────────────────────────────────────────────────────────────
# Node / docs site tooling
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
scripts/node_modules/
docs/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.backup

# ─────────────────────────────────────────────────────────────────────────────
# Vercel
# ─────────────────────────────────────────────────────────────────────────────
.vercel/
docs/.vercel/

# ─────────────────────────────────────────────────────────────────────────────
# Editor / IDE
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────────────────────
# Agent / research output (per-session)
# ─────────────────────────────────────────────────────────────────────────────
.agents/

# ─────────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────────
*.log
